# ═══════════════════════════════════════════════════════════════
# Wordle Global — Environment Variables
# Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════

# ─── Database ───
# Postgres connection string. Uses the `wordle` schema.
DATABASE_URL="postgresql://user:password@host:5432/database"

# ─── Auth: Session ───
# 32+ character random string for encrypting session cookies.
# Generate with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=""

# ─── Auth: Google OAuth ───
# Get from: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://your-domain.com/auth/google
NUXT_OAUTH_GOOGLE_CLIENT_ID=""
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=""

# ─── Auth: Email tokens ───
# Separate secret for HMAC-signing email verification + password reset tokens.
# If not set, falls back to NUXT_SESSION_PASSWORD. Generate separately for defense in depth.
# Generate with: openssl rand -base64 32
NUXT_EMAIL_TOKEN_SECRET=""

# ─── Email: Resend (optional) ───
# Required for email/password auth (verification emails, password reset).
# Not required for Google or passkey auth.
# Get from: https://resend.com/api-keys
RESEND_API_KEY=""

# ─── App ───
# Base URL for links in emails (verification, password reset).
NUXT_BASE_URL="http://localhost:3000"

# ─── Dev tools ───
# Set to "true" to enable /api/auth/dev-login (bypasses OAuth for testing).
# NEVER enable in production.
ALLOW_DEV_LOGIN="true"

# ─── LLM (existing) ───
# OpenAI API key for definitions and semantic mode.
OPENAI_API_KEY=""

# ─── Data (existing, optional) ───
# Override the default data directory (defaults to ./data/).
# DATA_DIR=""
