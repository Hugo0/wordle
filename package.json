{
    "name": "wordle-global",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.17.1",
    "scripts": {
        "dev": "nuxt dev",
        "build": "nuxt build",
        "preview": "nuxt preview",
        "generate": "nuxt generate",
        "postinstall": "nuxt prepare",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test --config playwright.config.ts",
        "test:e2e:headed": "playwright test --config playwright.config.ts --headed",
        "format": "prettier --write \"**/*.{ts,js,vue,json}\"",
        "format:check": "prettier --check \"**/*.{ts,js,vue,json}\""
    },
    "dependencies": {
        "@khmyznikov/pwa-install": "^0.6.2",
        "@pinia/nuxt": "^0.10.1",
        "@posthog/nuxt": "^1.5.87",
        "nuxt": "^3.17.5",
        "openai": "^5.8.2",
        "pinia": "^3.0.3",
        "proper-lockfile": "^4.1.2",
        "sharp": "^0.34.3",
        "vue": "^3.5.27"
    },
    "pnpm": {
        "ignoredBuiltDependencies": [
            "esbuild"
        ]
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/vite": "^4.1.18",
        "@types/proper-lockfile": "^4.1.4",
        "@vite-pwa/nuxt": "^0.10.8",
        "jsdom": "^27.4.0",
        "playwright": "^1.58.2",
        "prettier": "^3.8.1",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.0.18",
        "vue-tsc": "^3.2.3"
    }
}
