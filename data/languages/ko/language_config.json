            { "key": "free", "title": "\uc601\uc6d0\ud788 \ubb34\ub8cc", "desc": "\uacc4\uc815 \ud544\uc694 \uc5c6\uc74c. \uc720\ub8cc \uacb0\uc81c \uc5c6\uc74c. \uadf8\ub0e5 \ud50c\ub808\uc774\ud558\uc138\uc694." }
        ],
        "tips": [
            { "title": "\ubaa8\uc74c\uc774 \ub9ce\uc740 \ub2e8\uc5b4\ub85c \uc2dc\uc791\ud558\uc138\uc694", "text": "CRANE, STARE, ADIEU \uac19\uc740 \ub2e8\uc5b4\ub294 \uc790\uc8fc \uc4f0\uc774\ub294 \uae00\uc790\ub97c \ube68\ub9ac \ud14c\uc2a4\ud2b8\ud569\ub2c8\ub2e4. \uc5b4\ub5a4 \ubaa8\uc74c\uc774 \uc788\ub294\uc9c0 \uc54c\uba74 \ud6c8\uc52c \uc88b\uc544\uc694." },
            { "title": "\uc54c\uc544\ub0b8 \uc815\ubcf4\ub97c \ud65c\uc6a9\ud558\uc138\uc694", "text": "\ucd08\ub85d\uc0c9 \uae00\uc790\ub294 \ud655\uc815. \ub178\ub780\uc0c9 \uae00\uc790\ub294 \uc704\uce58\ub97c \ubc14\uafd4\uc57c \ud574\uc694. \ud68c\uc0c9 \uae00\uc790\ub294 \uc81c\uc678. \ub9e4\ubc88 \uc138 \uac00\uc9c0 \ub2e8\uc11c\ub97c \ubaa8\ub450 \ud65c\uc6a9\ud558\uc138\uc694." },
            { "title": "\uc790\uc8fc \ub098\uc624\ub294 \ud328\ud134\uc744 \uc0dd\uac01\ud558\uc138\uc694", "text": "\uc5b8\uc5b4\ub9c8\ub2e4 \uc790\uc8fc \ub098\uc624\ub294 \ud328\ud134\uc774 \uc788\uc5b4\uc694. \uadf8 \ud328\ud134\uc744 \uc775\ud600\ub450\uba74 \ub354 \ube68\ub9ac \ud480 \uc218 \uc788\uc5b4\uc694." },
            { "title": "\ubb34\uc791\uc704\ub85c \ucd94\uce21\ud558\uc9c0 \ub9c8\uc138\uc694", "text": "\ub450 \ubc88\uc9f8 \ub2e8\uc5b4\ub294 \uc0c8\ub85c\uc6b4 \uae00\uc790\ub97c \ud14c\uc2a4\ud2b8\ud574\uc57c \ud574\uc694. \uac80\uc99d\ub418\uc9c0 \uc54a\uc740 \uc790\uc74c\uc744 \ucd5c\ub300\ud55c \ub9ce\uc774 \uc2dc\ub3c4\ud558\uc138\uc694." },
            { "title": "\uac19\uc740 \uae00\uc790\uac00 \ub450 \ubc88 \ub098\uc62c \uc218 \uc788\uc5b4\uc694", "text": "CREEK, FLOSS, APPLE \uac19\uc740 \ub2e8\uc5b4\ub294 \ud754\ud55c \ud568\uc815\uc774\uc5d0\uc694. \ub2e8\uc11c\uac00 \ub9de\uc9c0 \uc54a\uc73c\uba74 \ubc18\ubcf5\ub418\ub294 \uae00\uc790\ub97c \uace0\ub824\ud574\ubcf4\uc138\uc694." },
            { "title": "\ud558\ub4dc \ubaa8\ub4dc\ub85c \uc2e4\ub825\uc744 \ub192\uc774\uc138\uc694", "text": "\ud558\ub4dc \ubaa8\ub4dc\ub294 \ud655\uc815\ub41c \ub2e8\uc11c\ub97c \ubc18\ub4dc\uc2dc \uc0ac\uc6a9\ud558\uac8c \ud569\ub2c8\ub2e4. \ub354 \uc88b\uc740 \uc2b5\uad00\uc744 \ub9cc\ub4e4\uc5b4 \uc918\uc694." }
        ],
        "tips_speed": [
            { "title": "CRANE\uc774\ub098 STARE\ub85c \uc2dc\uc791\ud558\uc138\uc694", "text": "\uc790\uc8fc \uc4f0\uc774\ub294 \uae00\uc790\uac00 \ube60\ub978 \ud480\uc774\uc758 \ucd5c\uc120\uc785\ub2c8\ub2e4. 1\ucd08\uac00 \uc544\uc27d\uc5b4\uc694." },
            { "title": "\ub108\ubb34 \uc624\ub798 \uace0\ubbfc\ud558\uc9c0 \ub9c8\uc138\uc694", "text": "Speed Streak\uc740 \uc9c1\uac10\uc774 \uc911\uc694\ud574\uc694. \ub9de\uc744 \uac83 \uac19\uc740 \ub2e8\uc5b4\uac00 \ubcf4\uc774\uba74 \ubc14\ub85c \uc2dc\ub3c4\ud558\uc138\uc694 \u2014 \ucf64\ubcf4 \ubcf4\ub108\uc2a4\uac00 \ub354 \ucee4\uc694." },
            { "title": "\ucf64\ubcf4\ub97c \uc9c0\ud0a4\uc138\uc694", "text": "\uc2e4\ud328\ud558\uba74 \ubc30\uc728\uc774 \uae68\uc838\uc694. \ud655\uc2e4\ud558\uc9c0 \uc54a\uc73c\uba74 \uc548\uc804\ud55c \ucd94\uce21\uc73c\ub85c \ub2e8\uc11c\ub97c \ubaa8\uc73c\uc138\uc694." },
            { "title": "2-3\ubc88 \ub9cc\uc5d0 \ud480\uae30\ub97c \ubaa9\ud45c\ub85c", "text": "\ube60\ub978 \ud480\uc774\uc758 \uc2dc\uac04 \ubcf4\ub108\uc2a4\uac00 \uc5c4\uccad\ub098\uc694 (+60\ucd08 1\ubc88 \ud480\uc774, +30\ucd08 2\ubc88). \ubaa8\ud5d8\uc801\uc778 \ub450 \ubc88\uc9f8 \ucd94\uce21\uc774 \ud070 \ubcf4\uc0c1\uc744 \uc904 \uc218 \uc788\uc5b4\uc694." },
            { "title": "\uc790\uc8fc \ub098\uc624\ub294 \ub2e8\uc5b4 \ub05d\uc744 \uc678\uc6b0\uc138\uc694", "text": "-IGHT, -OUND, -ATCH \uac19\uc740 \ud328\ud134\uc774 \uc790\uc8fc \ubc18\ubcf5\ub3fc\uc694. \ubc14\ub85c \uc54c\uc544\ubcf4\uba74 \ub2e8\uc5b4\ub2f9 \uba87 \ucd08\uc529 \uc808\uc57d\ud560 \uc218 \uc788\uc5b4\uc694." },
            { "title": "\uc555\ubc15\uc774 \ucee4\uc838\ub3c4 \uce68\ucc29\ud558\uc138\uc694", "text": "3\uac1c \ub2e8\uc5b4\ub9c8\ub2e4 \ud0c0\uc774\uba38\uac00 \ube68\ub77c\uc838\uc694. \uc11c\ub450\ub974\uba74 \uc624\ud0c0\uc640 \ub098\uc05c \ucd94\uce21\uc774 \ub098\uc640\uc694. \uafb8\uc900\ud55c \ud398\uc774\uc2a4\uac00 \ucd5c\uace0\uc608\uc694." }
        ],
        "tips_multiboard": [
            { "title": "\ub113\uac8c \uc2dc\uc791\ud558\uc138\uc694", "text": "\uc790\uc8fc \uc4f0\uc774\ub294 \uae00\uc790 \ub2e8\uc5b4(CRANE, STARE)\ub85c \ubaa8\ub4e0 \ubcf4\ub4dc\uc5d0\uc11c \ub2e8\uc11c\ub97c \ubaa8\uc73c\uc138\uc694." },
            { "title": "\ubd84\ud560 \ud0a4\ubcf4\ub4dc\ub97c \ud655\uc778\ud558\uc138\uc694", "text": "\ud0a4\ubcf4\ub4dc\uac00 \ubcf4\ub4dc\ubcc4\ub85c \uc0c9\uc744 \ubcf4\uc5ec\uc918\uc694. \ud55c \ubcf4\ub4dc\uc5d0\uc11c \ucd08\ub85d\uc0c9\uc778\ub370 \ub2e4\ub978 \ubcf4\ub4dc\uc5d0\uc11c \ud68c\uc0c9\uc774\uba74 \ube60\ub974\uac8c \ubc94\uc704\ub97c \uc904\uc77c \uc218 \uc788\uc5b4\uc694." },
            { "title": "\uc5b4\ub824\uc6b4 \ubcf4\ub4dc\uc5d0 \uc9d1\uc911\ud558\uc138\uc694", "text": "\ubaa8\ub974\ub294 \uac83\uc774 \uac00\uc7a5 \ub9ce\uc740 \ubcf4\ub4dc\uc5d0 \ucd94\uce21\uc744 \uc9d1\uc911\ud558\uc138\uc694. \uc26c\uc6b4 \ubcf4\ub4dc\ub294 \uc800\uc808\ub85c \ud480\ub9ac\ub294 \uacbd\uc6b0\uac00 \ub9ce\uc544\uc694." },
            { "title": "\ucd08\ubc18 \ucd94\uce21\uc744 \ub0ad\ube44\ud558\uc9c0 \ub9c8\uc138\uc694", "text": "\ucc98\uc74c 2-3\ubc88\uc740 \uc815\ubcf4 \uc218\uc9d1\uc6a9 \ub2e8\uc5b4\ub97c \uc4f0\uace0, \uadf8 \ud6c4\uc5d0 \ud2b9\uc815 \ubcf4\ub4dc\ub97c \ub178\ub9ac\uc138\uc694." },
            { "title": "\uacf5\ud1b5 \uae00\uc790\ub97c \ucc3e\uc73c\uc138\uc694", "text": "\ub450 \ubcf4\ub4dc\uc5d0\uc11c \ub458 \ub2e4 \ub178\ub780\uc0c9 E\uac00 \ub098\uc624\uba74, E\ub97c \uc0c8 \uc704\uce58\uc5d0 \ub123\uc740 \ub2e8\uc5b4\uac00 \ub458 \ub2e4 \ub3c4\uc6c0\uc774 \ub3fc\uc694." },
            { "title": "\ub9c8\uc9c0\ub9c9 \ucd94\uce21\uc744 \ub0a8\uaca8\ub450\uc138\uc694", "text": "\ub9c8\uc9c0\ub9c9 \ubcf4\ub4dc\uc5d0\uc11c \ub9c9\ud788\uba74 \uc5ec\ubd84\uc758 \ucd94\uce21\uc774 \uc2b9\ud328\ub97c \uac00\ub985\ub2c8\ub2e4." }
        ],
        "mode_desc_classic": "6\ubc88\uc758 \uae30\ud68c \uc548\uc5d0 \uc228\uaca8\uc9c4 5\uae00\uc790 \ub2e8\uc5b4\ub97c \ub9de\ud600\ubcf4\uc138\uc694. \uc0c9\uc0c1 \ub2e8\uc11c\ub97c \ud65c\uc6a9\ud574 \uc815\ub2f5\uc744 \uc88b\ud600\uac00\uc138\uc694.",
        "mode_desc_unlimited": "6\ubc88\uc758 \uae30\ud68c \uc548\uc5d0 \uc228\uaca8\uc9c4 5\uae00\uc790 \ub2e8\uc5b4\ub97c \ub9de\ud600\ubcf4\uc138\uc694. \uc0c9\uc0c1 \ub2e8\uc11c\ub97c \ud65c\uc6a9\ud574 \uc815\ub2f5\uc744 \uc88b\ud600\uac00\uc138\uc694. \uac8c\uc784 \ud6c4 \"\ub2e4\uc2dc \ud50c\ub808\uc774\"\ub97c \ub20c\ub7ec \ubc14\ub85c \uc0c8 \ub2e8\uc5b4\ub97c \ubc1b\uc73c\uc138\uc694 \u2014 \ud69f\uc218 \uc81c\ud55c \uc5c6\uc74c.",
        "mode_desc_speed": "3\ubd84\uc758 \uc2dc\uac04\uc73c\ub85c \uc2dc\uc791\ud569\ub2c8\ub2e4. \ub2e8\uc5b4\ub97c \ud480\uba74 \ubcf4\ub108\uc2a4 \uc2dc\uac04\uc744 \ubc1b\uc544\uc694 \u2014 \uc801\uc740 \ucd94\uce21\uc73c\ub85c \ud480\uc218\ub85d \ub354 \ub9ce\uc774 (+60\ucd08 1\ubc88 \ud480\uc774, +10\ucd08 6\ubc88). \uc2e4\ud328\ud558\uba74 30\ucd08 \uac10\uc18c. \uc5f0\uc18d \ud480\uc774\ub85c \ucf64\ubcf4\ub97c \uc313\uc544 \ucd5c\ub300 3\ubc30 \ubcf4\ub108\uc2a4. 3\uac1c \ub2e8\uc5b4\ub9c8\ub2e4 \ud0c0\uc774\uba38\uac00 \ube68\ub77c\uc838\uc694.",
        "mode_desc_multiboard": "{modeName}\uc740 {boardCount}\uac1c\uc758 Wordle \ubcf4\ub4dc\ub97c {maxGuesses}\ubc88\uc758 \ucd94\uce21\uc73c\ub85c \ub3d9\uc2dc\uc5d0 \ud478\ub294 \ubaa8\ub4dc\uc785\ub2c8\ub2e4. \ucd94\uce21\uc740 \ubaa8\ub4e0 \ubbf8\ud574\uacb0 \ubcf4\ub4dc\uc5d0 \ub3d9\uc2dc \uc801\uc6a9\ub429\ub2c8\ub2e4. \ud480\ub9b0 \ubcf4\ub4dc\ub294 \uace0\uc815\ub429\ub2c8\ub2e4. \ubd84\ud560 \ud0a4\ubcf4\ub4dc\ub85c \uc5b4\ub5a4 \uae00\uc790\uac00 \uc5b4\ub5a4 \ubcf4\ub4dc\uc5d0 \ub9de\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694. \uc790\uc8fc \uc4f0\uc774\ub294 \uae00\uc790\ub85c \uc2dc\uc791\ud574 \ubaa8\ub4e0 \ubcf4\ub4dc\uc758 \ub2e8\uc11c\ub97c \ubaa8\uc73c\uc138\uc694.",
        "faq": [
            { "q": "{langName}\ub85c Wordle\uc744 \uc5b4\ub5bb\uac8c \ud558\ub098\uc694?", "a": "wordle.global/{lang}\uc5d0\uc11c {langName} \uc77c\uc77c Wordle\uc744 \ud50c\ub808\uc774\ud558\uc138\uc694. 6\ubc88 \uc548\uc5d0 5\uae00\uc790 \ub2e8\uc5b4\ub97c \ub9de\ud600\uc57c \ud574\uc694. \ucd08\ub85d\uc0c9(\ub9de\ub294 \uae00\uc790, \ub9de\ub294 \uc704\uce58), \ub178\ub780\uc0c9(\ub9de\ub294 \uae00\uc790, \ud2c0\ub9b0 \uc704\uce58), \ud68c\uc0c9(\uc5c6\ub294 \uae00\uc790)\uc73c\ub85c \ub2e8\uc11c\ub97c \uc904 \uc218 \uc788\uc5b4\uc694." },
            { "q": "\ub9e4\uc77c \uc0c8\ub85c\uc6b4 \ud37c\uc990\uc774 \uc788\ub098\uc694?", "a": "\ub124. \ub9e4\uc77c \uc0c8 \ub2e8\uc5b4\uac00 \uc120\ud0dd\ub3fc\uc694. \uac19\uc740 \uc5b8\uc5b4\ub85c \ud558\ub294 \ubaa8\ub4e0 \uc0ac\ub78c\uc774 \uac19\uc740 \ub2e8\uc5b4\ub97c \ubc1b\uc73c\ubbc0\ub85c \uce5c\uad6c\uc640 \uacb0\uacfc\ub97c \ube44\uad50\ud560 \uc218 \uc788\uc5b4\uc694." },
            { "q": "Wordle Global\uc740 \ubb34\ub8cc\uc778\uac00\uc694?", "a": "\ub124. \uc77c\uc77c \ud37c\uc990, \ubb34\uc81c\ud55c \ubaa8\ub4dc, \ubaa8\ub4e0 \uac8c\uc784 \ubaa8\ub4dc\uac00 80\uac1c \uc774\uc0c1\uc758 \uc5b8\uc5b4\ub85c \uc644\uc804 \ubb34\ub8cc\uc785\ub2c8\ub2e4. \uacc4\uc815\uc774\ub098 \ub2e4\uc6b4\ub85c\ub4dc \ud544\uc694 \uc5c6\uc5b4\uc694." },
            { "q": "\ud558\ub8e8\uc5d0 \uc5ec\ub7ec \ubc88 \ud560 \uc218 \uc788\ub098\uc694?", "a": "\ub124 \u2014 wordle.global/{lang}/unlimited\uc5d0\uc11c \ubb34\uc81c\ud55c \ubaa8\ub4dc\ub97c \uc990\uae30\uc138\uc694. \uae30\ub2e4\ub9bc \uc5c6\uc774 \uacc4\uc18d \ud50c\ub808\uc774\ud560 \uc218 \uc788\uc5b4\uc694. \uc77c\uc77c \uc5f0\uc18d \uae30\ub85d\uc740 \ubcc4\ub3c4\ub85c \uad00\ub9ac\ub3fc\uc694." }
        ],
        "mode_faq": {
            "unlimited": [
                { "q": "{langName}\uc73c\ub85c Wordle \ubb34\uc81c\ud55c\uc774 \ubb50\uc608\uc694?", "a": "Wordle \ubb34\uc81c\ud55c\uc740 {langName}\ub85c \uc6d0\ud558\ub294 \ub9cc\ud07c Wordle\uc744 \ud50c\ub808\uc774\ud560 \uc218 \uc788\uc5b4\uc694. \ub0b4\uc77c\uc758 \ud37c\uc990\uc744 \uae30\ub2e4\ub9b4 \ud544\uc694 \uc5c6\uc774 \ub9e4\ubc88 \uc0c8 \ub2e8\uc5b4\ub97c 6\ubc88 \uc548\uc5d0 \ub9de\ud600\ubcf4\uc138\uc694." },
                { "q": "Wordle \ubb34\uc81c\ud55c\uc740 \ubb34\ub8cc\uc778\uac00\uc694?", "a": "\ub124. Wordle \ubb34\uc81c\ud55c\uc740 \uc644\uc804 \ubb34\ub8cc\uc785\ub2c8\ub2e4. \uacc4\uc815 \ud544\uc694 \uc5c6\uace0, \ub2e4\uc6b4\ub85c\ub4dc \ud544\uc694 \uc5c6\uace0, \uac8c\uc784 \uc911 \uad11\uace0\ub3c4 \uc5c6\uc5b4\uc694." },
                { "q": "\ubb34\uc81c\ud55c \ubaa8\ub4dc\uac00 \uc77c\uc77c \uc5f0\uc18d \uae30\ub85d\uc5d0 \uc601\ud5a5\uc744 \uc8fc\ub098\uc694?", "a": "\uc544\ub2c8\uc694. \ubb34\uc81c\ud55c \ubaa8\ub4dc\ub294 \ubcc4\ub3c4 \ud1b5\uacc4\ub97c \uac16\uace0 \uc788\uc5b4\uc694. \uc77c\uc77c \uc5f0\uc18d \uae30\ub85d\uc740 \ub370\uc77c\ub9ac \ud37c\uc990\uc5d0\ub9cc \uc601\ud5a5\uc744 \ubc1b\uc544\uc694." },
                { "q": "\uba87 \ubc88\uc774\ub098 \ud560 \uc218 \uc788\ub098\uc694?", "a": "\uc81c\ud55c \uc5c6\uc774 \uc6d0\ud558\ub294 \ub9cc\ud07c \ud50c\ub808\uc774\ud558\uc138\uc694. \uac8c\uc784 \ud6c4 \"\ub2e4\uc2dc \ud50c\ub808\uc774\"\ub97c \ub20c\ub7ec \ubc14\ub85c \uc0c8 \ub2e8\uc5b4\ub97c \ubc1b\uc73c\uc138\uc694." },
                { "q": "Wordle \ubb34\uc81c\ud55c\uc744 \uc5b4\ub5a4 \uc5b8\uc5b4\ub85c \ud560 \uc218 \uc788\ub098\uc694?", "a": "Wordle \ubb34\uc81c\ud55c\uc740 wordle.global\uc5d0\uc11c 80\uac1c \uc774\uc0c1\uc758 \uc5b8\uc5b4\ub85c \uc774\uc6a9 \uac00\ub2a5\ud569\ub2c8\ub2e4. \uc601\uc5b4, \uc2a4\ud398\uc778\uc5b4, \ub3c5\uc77c\uc5b4, \ud540\ub780\ub4dc\uc5b4, \uc544\ub78d\uc5b4, \ud504\ub791\uc2a4\uc5b4, \uc774\ud0c8\ub9ac\uc544\uc5b4, \ud3ec\ub974\ud22c\uac08\uc5b4 \ub4f1 \ub2e4\uc591\ud55c \uc5b8\uc5b4\ub97c \uc9c0\uc6d0\ud569\ub2c8\ub2e4." }
            ],
            "speed": [
                { "q": "{langName}\uc73c\ub85c Speed Streak\uc774 \ubb50\uc608\uc694?", "a": "Speed Streak\uc740 {langName}\uc758 \uc2dc\uac04 \uc81c\ud55c Wordle \ubaa8\ub4dc\uc785\ub2c8\ub2e4. 3\ubd84\uc73c\ub85c \uc2dc\uc791\ud574\uc11c \ucd5c\ub300\ud55c \ub9ce\uc740 \ub2e8\uc5b4\ub97c \ud480\uc5b4\ubcf4\uc138\uc694. \ube68\ub9ac \ud480\uba74 \ubcf4\ub108\uc2a4 \uc2dc\uac04\uc744 \ubc1b\uc544\uc694." },
                { "q": "\uc810\uc218\ub294 \uc5b4\ub5bb\uac8c \uacc4\uc0b0\ub418\ub098\uc694?", "a": "\ub2e8\uc5b4\ub97c \ud480 \ub54c\ub9c8\ub2e4 \uc810\uc218\ub97c \ubc1b\uc544\uc694. \uc801\uc740 \ucd94\uce21\uacfc \ube60\ub978 \ud480\uc774\uc77c\uc218\ub85d \ub354 \ub9ce\uc740 \uc810\uc218\ub97c \ubc1b\uc544\uc694. \uc5f0\uc18d \ud480\uc774\ub85c \ucf64\ubcf4\ub97c \uc313\uc544 \ucd5c\ub300 3\ubc30 \ubcf4\ub108\uc2a4\ub97c \ubc1b\uc73c\uc138\uc694." },
                { "q": "\uc2dc\uac04\uc774 \ub2e4 \ub418\uba74 \uc5b4\ub5bb\uac8c \ub418\ub098\uc694?", "a": "\uac8c\uc784\uc774 \ub05d\ub098\uace0 \ucd5c\uc885 \uc810\uc218, \ud47c \ub2e8\uc5b4 \uc218, \ucd5c\ub300 \ucf64\ubcf4, \ud3c9\uade0 \ucd94\uce21 \ud69f\uc218\ub97c \ud655\uc778\ud560 \uc218 \uc788\uc5b4\uc694. \ubc14\ub85c \ub2e4\uc2dc \ud50c\ub808\uc774\ud560 \uc218 \uc788\uc5b4\uc694." },
                { "q": "Speed Streak\uc740 \ubb34\ub8cc\uc778\uac00\uc694?", "a": "\ub124. Speed Streak\uc740 80\uac1c \uc774\uc0c1\uc758 \uc5b8\uc5b4\ub85c \uc644\uc804 \ubb34\ub8cc\uc785\ub2c8\ub2e4. \uacc4\uc815\uc774\ub098 \ub2e4\uc6b4\ub85c\ub4dc \ud544\uc694 \uc5c6\uc5b4\uc694." }
